{
    "version": 2,
    "framework": null,
    "installCommand": "composer install --no-dev --optimize-autoloader && npm install",
    "buildCommand": "npm run build && php artisan config:cache && php artisan route:cache && php artisan view:cache",
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.2"
        }
    },
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/(.*\\.(css|js|ico|png|jpg|jpeg|gif|svg|woff|woff2|ttf|eot)$)",
            "dest": "/public/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}
